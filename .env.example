# ─── Sui Network — MAINNET ───
NEXT_PUBLIC_SUI_NETWORK=mainnet
NEXT_PUBLIC_TATUM_MAINNET_RPC_URL=https://sui-mainnet.gateway.tatum.io
NEXT_PUBLIC_TATUM_RPC_URL=https://sui-mainnet.gateway.tatum.io
NEXT_PUBLIC_TATUM_API_KEY=your-tatum-api-key

# ─── Walrus storage — MAINNET ───
SUI_PRIVATE_KEY=your-sui-private-key
NEXT_PUBLIC_WALRUS_NETWORK=mainnet
WALRUS_PUBLISHER_URL=https://publisher.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-mainnet.walrus.space
WALRUS_EPOCHS=52
# Optional for authenticated publishers only; never expose this as NEXT_PUBLIC.
WALRUS_PUBLISHER_AUTH_TOKEN=your-walrus-publisher-token

# ─── AI Advisor ───
DEEPSEEK_API_KEY=sk-......-key
