# ─── Tatum RPC (REQUIRED for Sui RPC integration) ───
NEXT_PUBLIC_TATUM_RPC_URL=https://sui-testnet.gateway.tatum.io
NEXT_PUBLIC_TATUM_API_KEY=your-tatum-api-key-here

# ─── Walrus Server-Side Signing (REQUIRED for certified blobs) ───
SUI_PRIVATE_KEY=suiprivkey...

# ─── Network (optional, default: mainnet) ───
NEXT_PUBLIC_WALRUS_NETWORK=testnet

# ─── DeepSeek AI (REQUIRED for AI Advisor) ───
DEEPSEEK_API_KEY=sk-...
